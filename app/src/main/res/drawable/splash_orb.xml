<?xml version="1.0" encoding="utf-8"?>
<!-- splash_orb.xml — Large cinematic splash orb -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep glow layer -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#3300D4FF" />
            <size android:width="90dp" android:height="90dp" />
        </shape>
    </item>

    <!-- Inner border -->
    <item
        android:top="4dp" android:bottom="4dp"
        android:left="4dp" android:right="4dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#8800D4FF" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Gradient body -->
    <item
        android:top="6dp" android:bottom="6dp"
        android:left="6dp" android:right="6dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="100%"
                android:centerX="0.3"
                android:centerY="0.3"
                android:startColor="#FF00D4FF"
                android:centerColor="#990099BB"
                android:endColor="#FF050A12" />
        </shape>
    </item>

</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <!-- ─── DASHBOARD ─────────────────────── -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.codexkd.vivoassistant.ui.DashboardFragment"
        android:label="Home"
        tools:layout="@layout/fragment_dashboard">

        <action
            android:id="@+id/action_dashboard_to_chat"
            app:destination="@id/chatFragment"
            app:enterAnim="@anim/slide_up_fade_in"
            app:exitAnim="@anim/fade_out_scale"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_down_fade_out" />

        <action
            android:id="@+id/action_dashboard_to_routines"
            app:destination="@id/routinesFragment"
            app:enterAnim="@anim/slide_up_fade_in"
            app:exitAnim="@anim/fade_out_scale" />
    </fragment>

    <!-- ─── AI CHAT ───────────────────────── -->
    <fragment
        android:id="@+id/chatFragment"
        android:name="com.codexkd.vivoassistant.ui.ChatFragment"
        android:label="AI Chat"
        tools:layout="@layout/fragment_chat">

        <!-- Optional pre-filled text from voice command -->
        <argument
            android:name="prefill_text"
            app:argType="string"
            android:defaultValue="" />

        <action
            android:id="@+id/action_chat_to_settings"
            app:destination="@id/settingsActivity"
            app:enterAnim="@anim/slide_up_fade_in"
            app:exitAnim="@anim/fade_out_scale" />
    </fragment>

    <!-- ─── ROUTINES ──────────────────────── -->
    <fragment
        android:id="@+id/routinesFragment"
        android:name="com.codexkd.vivoassistant.ui.RoutinesFragment"
        android:label="Routines"
        tools:layout="@layout/fragment_routines" />

    <!-- ─── SETTINGS (Activity) ───────────── -->
    <activity
        android:id="@+id/settingsActivity"
        android:name="com.codexkd.vivoassistant.ui.SettingsActivity"
        android:label="Settings" />

</navigation>

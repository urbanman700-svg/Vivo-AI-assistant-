<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Expanded panel -->
        <androidx.cardview.widget.CardView
            android:id="@+id/expandedPanel"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/overlay_panel_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="VIVO"
                        android:textColor="@color/color_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2" />

                    <ImageButton
                        android:id="@+id/btnClose"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_close"
                        android:background="@drawable/bg_icon_btn"
                        android:padding="4dp"
                        app:tint="@color/text_secondary" />
                </LinearLayout>

                <!-- Status -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ask me anything..."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

                <!-- Waveform bar -->
                <LinearLayout
                    android:id="@+id/waveformBar"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginTop="8dp">

                    <View android:layout_width="3dp" android:layout_height="12dp"
                        android:background="@color/color_primary" android:layout_marginHorizontal="2dp"/>
                    <View android:layout_width="3dp" android:layout_height="20dp"
                        android:background="@color/color_primary" android:layout_marginHorizontal="2dp"/>
                    <View android:layout_width="3dp" android:layout_height="28dp"
                        android:background="@color/color_primary_light" android:layout_marginHorizontal="2dp"/>
                    <View android:layout_width="3dp" android:layout_height="20dp"
                        android:background="@color/color_primary" android:layout_marginHorizontal="2dp"/>
                    <View android:layout_width="3dp" android:layout_height="14dp"
                        android:background="@color/color_primary" android:layout_marginHorizontal="2dp"/>
                    <View android:layout_width="3dp" android:layout_height="24dp"
                        android:background="@color/color_primary_light" android:layout_marginHorizontal="2dp"/>
                    <View android:layout_width="3dp" android:layout_height="16dp"
                        android:background="@color/color_primary" android:layout_marginHorizontal="2dp"/>
                </LinearLayout>

                <!-- AI response output -->
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:maxHeight="120dp">

                    <TextView
                        android:id="@+id/tvChatOutput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"
                        android:visibility="gone" />
                </ScrollView>

                <!-- Input row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_overlay"
                    android:paddingHorizontal="10dp"
                    android:layout_marginTop="10dp">

                    <EditText
                        android:id="@+id/etChatInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Type a command..."
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:background="@null"
                        android:imeOptions="actionSend"
                        android:inputType="text|textNoSuggestions"
                        android:singleLine="true" />

                    <ImageButton
                        android:id="@+id/btnMic"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_mic"
                        android:background="@null"
                        android:padding="4dp"
                        app:tint="@color/color_primary" />

                    <ImageButton
                        android:id="@+id/btnSend"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_send"
                        android:background="@null"
                        android:padding="4dp"
                        app:tint="@color/color_primary" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Collapsed orb -->
        <FrameLayout
            android:id="@+id/orbContainer"
            android:layout_width="56dp"
            android:layout_height="56dp">

            <View
                android:id="@+id/orbPulse"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/orb_pulse_ring"
                android:alpha="0" />

            <View
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:background="@drawable/orb_main" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_vivo_orb"
                app:tint="@color/text_primary" />

        </FrameLayout>
    </LinearLayout>

</FrameLayout>

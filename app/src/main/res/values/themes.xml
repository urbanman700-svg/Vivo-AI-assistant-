<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.VivoAssistant" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryContainer">@color/bg_elevated</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorSecondaryContainer">@color/bg_card</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorTertiary">@color/color_accent</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorSurfaceVariant">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOutline">@color/border_subtle</item>
        <item name="colorOutlineVariant">@color/divider</item>
        <item name="colorError">@color/color_error</item>
        <item name="colorOnError">@color/text_primary</item>
        <item name="android:statusBarColor">@color/status_bar_color</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimation.Vivo</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="bottomNavigationStyle">@style/VivoBottomNav</item>
        <item name="floatingActionButtonStyle">@style/VivoFAB</item>
        <item name="materialCardViewStyle">@style/VivoCard</item>
        <item name="shapeAppearanceMediumComponent">@style/VivoShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/VivoShapeLarge</item>
    </style>

    <style name="Theme.VivoAssistant.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_splash</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">500</item>
        <item name="postSplashScreenTheme">@style/Theme.VivoAssistant</item>
        <item name="android:statusBarColor">@color/bg_splash</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="VivoBottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bg_surface</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="itemRippleColor">@color/color_primary_alpha15</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="VivoFAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/color_primary</item>
        <item name="tint">@color/bg_primary</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="VivoCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="VivoShapeMedium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="VivoShapeLarge" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="WindowAnimation.Vivo" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_up_fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out_scale</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_down_fade_out</item>
    </style>

</resources>
